PROJECT_NAME="URL Shortener API"
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/url_shortener"
REDIS_URL="redis://localhost:6379/0"
JWT_SECRET="super-secret-dev-jwt-key-replace-in-production-1234567890"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
RATE_LIMIT_SHORTEN_WINDOW=60
RATE_LIMIT_SHORTEN_MAX_REQUESTS=20
RATE_LIMIT_REDIRECT_WINDOW=60
RATE_LIMIT_REDIRECT_MAX_REQUESTS=120
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# Celery & RabbitMQ settings
CELERY_BROKER_URL="amqp://guest:guest@localhost:5672//"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# GeoIP settings
GEOIP_DATABASE_PATH="app/resources/GeoLite2-Country.mmdb"
